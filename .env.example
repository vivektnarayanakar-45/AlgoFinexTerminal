# POSTGRES
POSTGRES_USER=aft_user
POSTGRES_PASSWORD=secure_password
POSTGRES_DB=aft_db
DATABASE_URL=postgresql+asyncpg://aft_user:secure_password@postgres:5432/aft_db

# REDIS
REDIS_URL=redis://redis:6379/0

# BACKEND
BACKEND_PORT=8000
SECRET_KEY=your_super_secret_key_change_in_production

# FRONTEND
VITE_API_BASE_URL=http://localhost:8000/api
VITE_WS_BASE_URL=ws://localhost:8000/ws

# TIMESCALE
TIMESCALE_EXTENSION=on
